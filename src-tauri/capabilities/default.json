{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Carvis 主窗口能力：核心 API + shell(服务启动/端口清理依赖) + opener + 开机自启",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "autostart:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": true,
          "shell": true
        },
        {
          "name": "taskkill",
          "cmd": "taskkill",
          "args": true
        },
        {
          "name": "sh",
          "cmd": "sh",
          "args": true,
          "shell": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": true,
          "shell": true
        },
        {
          "name": "taskkill",
          "cmd": "taskkill",
          "args": true
        },
        {
          "name": "sh",
          "cmd": "sh",
          "args": true,
          "shell": true
        }
      ]
    }
  ]
}
